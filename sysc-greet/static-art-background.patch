+// addStaticArtBackground renders /usr/share/sysc-greet/static-art.txt as a full-screen
+// background, centered in the terminal. Login widget is layered on top by View().
+func (m model) addStaticArtBackground(content string, width, height int) string {
+	data, err := os.ReadFile("/usr/share/sysc-greet/static-art.txt")
+	if err != nil {
+		// File missing — return blank background so the greeter still works
+		blank := strings.Repeat(" ", width)
+		rows := make([]string, height)
+		for i := range rows {
+			rows[i] = blank
+		}
+		return strings.Join(rows, "\n")
+	}
+
+	lines := strings.Split(strings.TrimRight(string(data), "\n"), "\n")
+	artHeight := len(lines)
+
+	// Find widest line in the art
+	maxArtWidth := 0
+	for _, line := range lines {
+		if w := len([]rune(line)); w > maxArtWidth {
+			maxArtWidth = w
+		}
+	}
+
+	// Center the art block in the terminal
+	topPad := (height - artHeight) / 2
+	if topPad < 0 {
+		topPad = 0
+	}
+	leftPad := (width - maxArtWidth) / 2
+	if leftPad < 0 {
+		leftPad = 0
+	}
+
+	emptyLine := strings.Repeat(" ", width)
+	result := make([]string, height)
+	for row := 0; row < height; row++ {
+		artRow := row - topPad
+		if artRow < 0 || artRow >= artHeight {
+			result[row] = emptyLine
+			continue
+		}
+		runes := []rune(lines[artRow])
+		lineWidth := len(runes)
+		available := width - leftPad
+		if available <= 0 {
+			result[row] = emptyLine
+			continue
+		}
+		var line string
+		if leftPad > 0 {
+			line = strings.Repeat(" ", leftPad)
+		}
+		if lineWidth > available {
+			line += string(runes[:available])
+		} else {
+			line += string(runes)
+			line += strings.Repeat(" ", available-lineWidth)
+		}
+		result[row] = line
+	}
+	return strings.Join(result, "\n")
+}
